# Ollama Configuration (LOCAL - RECOMMENDED)
OLLAMA_MODEL=llama2:latest
OLLAMA_BASE_URL=http://localhost:11434

# Docker-specific Ollama URL (uncomment when using Docker)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# If using OpenAI instead
# OPENAI_API_KEY=sk-...

# If using Hugging Face
# HF_TOKEN=hf_...

# Debugging
DEBUG=false
